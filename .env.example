# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=brandwtch
POSTGRES_PASSWORD=brandwtch
POSTGRES_DB=brandwtch
DATABASE_URL=postgresql+asyncpg://brandwtch:brandwtch@localhost:5432/brandwtch

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Reddit API (https://www.reddit.com/prefs/apps) ────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=BrandWtch/1.0

# ── Twitter/X API v2 (https://developer.twitter.com) ─────────────────────────
TWITTER_BEARER_TOKEN=

# ── Google / SerpAPI (https://serpapi.com) ────────────────────────────────────
SERPAPI_KEY=

# ── News API (https://newsapi.org) ────────────────────────────────────────────
NEWS_API_KEY=

# ── YouTube Data API v3 (https://console.developers.google.com) ───────────────
YOUTUBE_API_KEY=

# ── AI Platform APIs ──────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ── Monitoring defaults ───────────────────────────────────────────────────────
DEFAULT_CRAWL_INTERVAL_MINUTES=60
MAX_MENTIONS_PER_CRAWL=100
# "vader" (default, no GPU) or "transformer" (higher accuracy, requires torch)
SENTIMENT_MODEL=vader
